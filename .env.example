# Copy to .env and fill in. Do NOT commit .env.

# --- Azure Blob Storage ---
STORAGE_ACCOUNT_NAME=
STORAGE_CONTAINER_RAW=raw
STORAGE_CONTAINER_PROCESSED=processed
# For local dev you can use the connection string; in Azure prefer Managed Identity.
STORAGE_CONNECTION_STRING=

# --- Azure Service Bus ---
SERVICEBUS_NAMESPACE=
SERVICEBUS_QUEUE_EXTRACTION=extraction
SERVICEBUS_CONNECTION_STRING=

# --- Azure AI Document Intelligence ---
DOCINTEL_ENDPOINT=
DOCINTEL_KEY=
# Custom model IDs (set after training in Document Intelligence Studio)
DOCINTEL_MODEL_ARRIVAL_NOTICE=
DOCINTEL_MODEL_CARRIER_INVOICE=
DOCINTEL_MODEL_PACKING_LIST=
DOCINTEL_MODEL_BOL=
# Prebuilt model id for commercial invoices
DOCINTEL_MODEL_INVOICE=prebuilt-invoice

# --- Azure SQL ---
# Prefer Managed Identity / Entra auth in Azure; connection string for local dev.
SQL_CONNECTION_STRING=

# --- Auth (Entra ID) ---
ENTRA_TENANT_ID=
ENTRA_API_CLIENT_ID=
ENTRA_API_AUDIENCE=

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=local
# Confidence below this gets flagged for analyst attention in the UI.
LOW_CONFIDENCE_THRESHOLD=0.80
