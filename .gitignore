# Samples may contain real customer data — keep out of git by default.
# Comment the next two lines if you intentionally want to version samples.
samples/**/*.pdf
!samples/**/SAMPLE_*.pdf

# Real cover-sheet workbooks contain live business data (vendors, invoice #s,
# G/L codes) — keep out of git. The README documents the expected format.
templates/cover-sheets/*.xlsx
templates/cover-sheets/*.xls

# Local persisted data (saved G/L defaults, etc.)
.localdata/
